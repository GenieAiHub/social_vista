# Copy to .env on the VPS and fill in real values. Do NOT commit .env.

# ---- Local Postgres (replaces Neon) ----
POSTGRES_USER=socialvista
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=socialvista

# ---- App ----
# Long random string used to sign admin JWTs.
SESSION_SECRET=change-me-long-random-string
# Groq API key powering the AI chat assistant.
GROQ_API_KEY=
# Canonical public origin (used for absolute email image URLs, etc.).
PUBLIC_APP_URL=https://socialvista.co.in

# First-run owner account (created only if no staff exist). Change after first login.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# ---- Email (Resend) — optional; without a key all sends are logged no-ops ----
RESEND_API_KEY=
# Must be on a Resend-verified domain to send to arbitrary recipients.
RESEND_FROM_EMAIL=Social Vista <noreply@socialvista.co.in>
# When set, internal "new lead" notifications are emailed here.
AGENCY_NOTIFICATION_EMAIL=

# ---- Cloudflare (OPTIONAL on the VPS) ----
# Not needed by this stack at runtime: the shared reverse proxy serves a Cloudflare
# Origin Certificate for TLS (no DNS-01 / ACME). Only set this if you want to manage
# DNS records from the box. Token needs Zone:DNS:Edit + Zone:Zone:Read.
CLOUDFLARE_API_TOKEN=
